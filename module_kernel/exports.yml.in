@PROJECT_NAME@:
  attributes: 0
  version:
    major: @PROJECT_VERSION_MAJOR@
    minor: @PROJECT_VERSION_MINOR@
  main:
    start: module_start
  libraries:
    @PROJECT_NAME@:
      syscall: true
      functions:
        - kvqmbtGetPairedDevices
        - kvqmbtConnectDevice
        - kvqmbtDisconnectDevice
        - log_paired_devices
