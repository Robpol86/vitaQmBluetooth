@PROJECT_NAME@:
  attributes: 0
  version:
    major: @PROJECT_VERSION_MAJOR@
    minor: @PROJECT_VERSION_MINOR@
  main:
    start: module_start
  libraries:
    @PROJECT_NAME@:
      syscall: true
      functions:
        - kvqmbt_is_connected
        - kvqmbt_connect_device
        - kvqmbt_disconnect_device
        - kvqmbt_get_paired_devices
